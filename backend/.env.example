# ── GoHighLevel ───────────────────────────────────────────────────────────────
# Private Integration Token — Settings → Integrations → API Keys → Create Key (Private)
GHL_API_KEY=your_private_integration_token_here

# Location ID — Settings → Business Profile → scroll to "Location ID"
GHL_LOCATION_ID=your_location_id_here

# ── Google Ads ────────────────────────────────────────────────────────────────
# Developer token — apply at ads.google.com/home/tools/manager-accounts/
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 credentials — create in Google Cloud Console (see README for steps)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Refresh token for pete@clinicmastery.com — generated once via the
# generate_refresh_token utility in the google-ads library (see README)
GOOGLE_ADS_REFRESH_TOKEN=

# Leave blank if you're not using an MCC / manager account
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── Gmail (for sending PDF audit reports) ────────────────────────────────────
# Use any Gmail address. GMAIL_APP_PASSWORD is a 16-char App Password — NOT your
# regular Gmail password. Generate one at: myaccount.google.com/apppasswords
# (Requires 2-step verification to be enabled on the account first)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────────
# URL the Next.js frontend is served from (used for CORS)
FRONTEND_URL=http://localhost:3000

# URL the Next.js frontend uses to call the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
